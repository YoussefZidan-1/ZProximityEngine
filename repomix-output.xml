    text: "Beyond\nThe\nVoid", elementCount: 12, splitBy: "line", fontSize: 5, lineHeight: 1.1, letterSpacing: 0, 
    wordSpacing: 0.25, reach: 1, falloff: 2.4, duration: 2, resetDuration: 2, ease: "elastic", resetEase: "elastic",
