  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YoussefZidan-1/ZProximityEngine"
  },
  "bugs": {
    "url": "https://github.com/YoussefZidan-1/ZProximityEngine/issues"
  },
  "homepage": "https://z-proximity-engine.vercel.app/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "prepublishOnly": "npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "react": "^18.0.0 || ^19.0.0",
